<h1>Where do you want to travel to?<h1>

<% airports_list = [] %> 
<% @all_airports.each do |a| %>
    <% airports_list << a.code %>
<% end %>

<%= form_with url: "/search", method: :get do |form| %>
    <%= form.label :departure_airport, "Leaving from:" %>
    <%= select_tag(:departure_airport, options_for_select(airports_list)) %>
    <%= form.label :arrival_airport, "Arrive at:" %>
    <%= select_tag(:arrival_airport, options_for_select(airports_list)) %>
    <%= form.label :passengers, "Number of passengers:" %>
    <%= select_tag(:passengers, options_for_select([1, 2, 3, 4])) %>
    <%= form.label :departure_date, "Departure date" %>
    <%= select_tag(:departure_date, options_for_select(@flight_dates_list)) %>
    <%= form.submit "Search flights" %>
<% end %>


<% if @on_the_date != nil %>
<h2>Available Flights:</h2>
    <% @on_the_date.each do |flight| %>
        <p>From <%= flight.departure_airport %> to <%= flight.arrival_airport %> at <%= flight.start %></p>
    <% end %>
<% end %>

<% if @available_flights != nil %>
    <h2>All available flights from <%= params[:departure_airport] %> are shown below</h2>
    <% @available_flights.each do |flight| %>
        <p>From <%= flight.departure_airport %> to <%= flight.arrival_airport %> at <%= flight.start %></p>
    <% end %>
<% end %>